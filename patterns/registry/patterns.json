{
  "version": 1,
  "source": "sources/docs/specifications/rk3-information-pattern-taxonomy-draft.md",
  "patterns": [
    {
      "id": "statistic",
      "name": "Statistic",
      "layer": 0,
      "definition": "A numeric fact presented as evidence, context, trend, scale, or outcome.",
      "positive_indicators": ["percentage", "count", "rate", "comparison"],
      "negative_indicators": ["page number", "citation marker without surrounding evidence", "standalone year", "legal identifier", "funding amount"],
      "required_fields": ["value"],
      "optional_fields": ["unit", "label", "qualifier", "time_period", "geography", "surrounding_claim"],
      "evidence_requirements": ["source_refs[0].quote contains the value"],
      "candidate_component_treatments": ["stat_card", "metric_row", "comparison_card"],
      "common_false_positives": ["years used only as publication dates", "section numbers", "bill numbers", "statutory citations", "money amounts that belong to funding events"],
      "validation_rules": ["value must appear in source quote"]
    },
    {
      "id": "funding_event",
      "name": "Funding Event",
      "layer": 1,
      "definition": "A discrete funding, grant, investment, loan, pledge, donor, or capital event with a funder, recipient, program, or award action.",
      "positive_indicators": ["currency amount with grant action", "pledge made by", "funded by", "awarded to", "investment by"],
      "negative_indicators": ["ordinary price mention", "aggregate funding total", "average grant size", "capital backlog", "economic impact total"],
      "required_fields": ["amount"],
      "optional_fields": ["funder", "recipient", "program", "purpose", "time_period", "relationship_edges"],
      "evidence_requirements": ["amount or funding context appears in source_refs"],
      "candidate_component_treatments": ["funding_event_card", "relationship_graph_edge"],
      "common_false_positives": ["financial statement totals without event context", "sector-wide funding totals", "repair backlogs", "return-on-investment statements"],
      "validation_rules": ["amount must appear in source quote"]
    },
    {
      "id": "impact_statement",
      "name": "Impact / Accomplishment Statement",
      "layer": 1,
      "definition": "A compact claim about what an organization, program, sector, or policy achieved, affected, needed, or produced.",
      "positive_indicators": ["created homes", "touched lives", "helped organizations", "capital backlog", "need", "impact", "outcome"],
      "negative_indicators": ["raw number without claim", "survey demographic makeup", "citation text"],
      "required_fields": ["statement_text"],
      "optional_fields": ["impact_type", "actor", "value", "time_period", "beneficiaries", "scope"],
      "evidence_requirements": ["statement_text appears in source_refs"],
      "candidate_component_treatments": ["impact_stat_card", "achievement_callout"],
      "common_false_positives": ["methodology sample sizes", "chart legends"],
      "validation_rules": ["must describe an accomplishment, need, outcome, or impact claim"]
    },
    {
      "id": "purpose_statement",
      "name": "Purpose Statement",
      "layer": 1,
      "definition": "A problem-framing statement that explains why an organization, initiative, or intervention exists or why its work matters.",
      "positive_indicators": ["the need to", "urgent", "exists to solve", "problem statement", "why this matters"],
      "negative_indicators": ["mission slogan", "vision statement", "raw impact outcome"],
      "required_fields": ["statement_text"],
      "optional_fields": ["problem", "audience", "stakes"],
      "evidence_requirements": ["statement_text appears in source_refs"],
      "candidate_component_treatments": ["purpose_callout", "problem_statement"],
      "common_false_positives": ["recommendations", "ordinary topic sentences"],
      "validation_rules": ["must explain why the work is needed, not only what happened"]
    },
    {
      "id": "legal_reference",
      "name": "Legal Reference",
      "layer": 0,
      "definition": "A statute, bill number, legal section, regulation, or codified legal citation.",
      "positive_indicators": ["HB/SB bill number", "USC citation", "section symbol", "parenthetical legal subsection"],
      "negative_indicators": ["ordinary numbered list item", "page number"],
      "required_fields": ["reference_text"],
      "optional_fields": ["reference_type", "jurisdiction", "context"],
      "evidence_requirements": ["reference_text appears in source_refs"],
      "candidate_component_treatments": ["legal_reference_badge", "citation_popover"],
      "common_false_positives": ["citation years", "footnote markers"],
      "validation_rules": ["reference_text must appear in source quote"]
    },
    {
      "id": "resource",
      "name": "Resource",
      "layer": 1,
      "definition": "A named program, guide, toolkit, data source, survey, report, grant program, database, or other reusable resource surfaced by the document.",
      "positive_indicators": ["program", "guide", "toolkit", "survey", "report", "database", "resource", "grant program"],
      "negative_indicators": ["ordinary organization name", "generic section heading"],
      "required_fields": ["resource_name"],
      "optional_fields": ["resource_type", "sponsor", "description"],
      "evidence_requirements": ["resource_name appears in source_refs"],
      "candidate_component_treatments": ["resource_card", "resource_list_item"],
      "common_false_positives": ["generic Title Case phrases"],
      "validation_rules": ["resource_name must appear in source quote"]
    },
    {
      "id": "quotation",
      "name": "Quotation",
      "layer": 0,
      "definition": "Verbatim or near-verbatim words attributed to a person, group, document, or source.",
      "positive_indicators": ["quotation marks", "blockquote styling", "speaker attribution"],
      "negative_indicators": ["scare quotes", "quoted single term"],
      "required_fields": ["quote_text"],
      "optional_fields": ["speaker_name", "speaker_title", "speaker_affiliation", "topic"],
      "evidence_requirements": ["quote_text is grounded in source_refs"],
      "candidate_component_treatments": ["pull_quote", "testimonial_card", "evidence_sidebar"],
      "common_false_positives": ["quoted terms inside ordinary prose"],
      "validation_rules": ["quote_text must not be invented"]
    },
    {
      "id": "named_entity",
      "name": "Named Entity",
      "layer": 0,
      "definition": "A named person, organization, place, program, law, funder, agency, or initiative.",
      "positive_indicators": ["proper nouns", "acronyms", "defined parentheticals"],
      "negative_indicators": ["ordinary capitalized sentence starts"],
      "required_fields": ["entity_text"],
      "optional_fields": ["entity_type", "acronym", "definition", "aliases"],
      "evidence_requirements": ["entity_text appears in source_refs"],
      "candidate_component_treatments": ["glossary_entry", "entity_profile_card"],
      "common_false_positives": ["title case headings"],
      "validation_rules": ["entity_text must appear in source quote"]
    },
    {
      "id": "source_note_reference",
      "name": "Source Note Reference",
      "layer": 0,
      "definition": "A footnote, endnote, citation marker, or source reference supporting nearby content.",
      "positive_indicators": ["IR refs runs", "footnote records", "source lines"],
      "negative_indicators": ["plain numbers that are not references"],
      "required_fields": ["marker"],
      "optional_fields": ["context", "note_text"],
      "evidence_requirements": ["marker is present in source_refs or IR refs run"],
      "candidate_component_treatments": ["citation_popover", "source_note_list"],
      "common_false_positives": ["years", "numbered list markers"],
      "validation_rules": ["marker must be grounded in IR"]
    },
    {
      "id": "date_time_period",
      "name": "Date / Time Period",
      "layer": 0,
      "definition": "A date, year, range, or time marker relevant to the content.",
      "positive_indicators": ["month year", "four-digit year", "date range"],
      "negative_indicators": ["citation years without content relevance"],
      "required_fields": ["value"],
      "optional_fields": ["context", "normalized_value"],
      "evidence_requirements": ["value appears in source_refs"],
      "candidate_component_treatments": ["timeline_marker", "date_badge"],
      "common_false_positives": ["footer publication dates"],
      "validation_rules": ["value must appear in source quote"]
    },
    {
      "id": "geography_place",
      "name": "Geography / Place",
      "layer": 0,
      "definition": "A place, state, country, region, or geography used as content context.",
      "positive_indicators": ["state names", "city names", "regional labels"],
      "negative_indicators": ["publisher address in colophon"],
      "required_fields": ["place"],
      "optional_fields": ["context", "place_type"],
      "evidence_requirements": ["place appears in source_refs"],
      "candidate_component_treatments": ["map_marker", "profile_badge"],
      "common_false_positives": ["mailing addresses"],
      "validation_rules": ["place must appear in source quote"]
    },
    {
      "id": "key_finding",
      "name": "Key Finding",
      "layer": 1,
      "definition": "A concise conclusion or insight the report wants the reader to retain.",
      "positive_indicators": ["finding headings", "we find", "this shows"],
      "negative_indicators": ["generic topic sentences"],
      "required_fields": ["finding_text"],
      "optional_fields": ["supporting_evidence_refs", "scope"],
      "evidence_requirements": ["finding_text appears in source_refs"],
      "candidate_component_treatments": ["key_finding_card", "summary_card"],
      "common_false_positives": ["section headings named Findings without a finding statement"],
      "validation_rules": ["must be a claim, not only a topic label"]
    },
    {
      "id": "recommendation",
      "name": "Recommendation",
      "layer": 2,
      "definition": "A proposed action, usually directed at a stakeholder. Deterministic Stage A should not emit this directly; recommendation-ness requires Stage B judgment about modality, addressee, and intent.",
      "positive_indicators": ["should", "must", "recommend", "increase", "fund", "create"],
      "negative_indicators": ["descriptive use of action verbs"],
      "required_fields": ["action"],
      "optional_fields": ["actor", "target", "rationale", "timeframe"],
      "evidence_requirements": ["action appears in source_refs"],
      "candidate_component_treatments": ["recommendation_card", "action_agenda_item"],
      "common_false_positives": ["capability statements"],
      "validation_rules": ["action must be grounded in source quote"]
    },
    {
      "id": "entity_relationship",
      "name": "Entity Relationship",
      "layer": 2,
      "definition": "A graph-ready relationship between people, organizations, initiatives, places, funders, laws, or programs.",
      "positive_indicators": ["speaker attribution", "person title and organization", "partnership wording", "funding relationship"],
      "negative_indicators": ["entities merely co-occurring without relationship language"],
      "required_fields": ["subject", "predicate", "object"],
      "optional_fields": ["subject_type", "object_type", "confidence_reason", "source_pattern_id"],
      "evidence_requirements": ["relationship evidence appears in source_refs"],
      "candidate_component_treatments": ["relationship_graph_edge", "entity_profile_link"],
      "common_false_positives": ["adjacent entities in unrelated list items"],
      "validation_rules": ["subject and object must be grounded in source quote"]
    },
    {
      "id": "question",
      "name": "Question",
      "layer": 1,
      "definition": "A question used as a prompt, heading, FAQ item, or guide structure.",
      "positive_indicators": ["question mark", "interrogative heading"],
      "negative_indicators": ["rhetorical punctuation inside a quote"],
      "required_fields": ["question_text"],
      "optional_fields": ["answer_context", "topic"],
      "evidence_requirements": ["question_text appears in source_refs"],
      "candidate_component_treatments": ["faq_item", "guide_prompt"],
      "common_false_positives": ["multiple questions merged into one paragraph"],
      "validation_rules": ["question_text must end with a question mark"]
    },
    {
      "id": "definition",
      "name": "Definition",
      "layer": 1,
      "definition": "A term and explanation pairing.",
      "positive_indicators": ["means", "refers to", "is defined as", "known as"],
      "negative_indicators": ["ordinary explanatory prose without a term"],
      "required_fields": ["term", "definition"],
      "optional_fields": ["aliases", "scope"],
      "evidence_requirements": ["term and definition appear in source_refs"],
      "candidate_component_treatments": ["definition_callout", "glossary_entry"],
      "common_false_positives": ["long paragraphs with many subjects"],
      "validation_rules": ["definition must be grounded in source quote"]
    },
    {
      "id": "callout",
      "name": "Callout",
      "layer": 1,
      "definition": "A visually or structurally emphasized content unit.",
      "positive_indicators": ["IR aside", "pull quote styling", "boxed text"],
      "negative_indicators": ["ordinary paragraph in reading flow"],
      "required_fields": ["callout_text"],
      "optional_fields": ["callout_type"],
      "evidence_requirements": ["callout_text appears in source_refs"],
      "candidate_component_treatments": ["callout_box", "sidebar"],
      "common_false_positives": ["layout containers without semantic emphasis"],
      "validation_rules": ["must anchor to an IR node"]
    },
    {
      "id": "callout_label",
      "name": "Callout / Module Label",
      "layer": 1,
      "definition": "A repeated editorial label or named module family such as In Their Own Words, Digging Deeper, or Policy in Action.",
      "positive_indicators": ["short styled heading", "repeated callout label", "module title"],
      "negative_indicators": ["one-off section heading", "ordinary paragraph lead"],
      "required_fields": ["label_text"],
      "optional_fields": ["module_type", "sample_content"],
      "evidence_requirements": ["label_text appears in source_refs"],
      "candidate_component_treatments": ["callout_style_token", "module_theme"],
      "common_false_positives": ["ordinary title-case headings"],
      "validation_rules": ["label must be short and visually or structurally associated with a callout"]
    },
    {
      "id": "metric_cluster",
      "name": "Metric Cluster",
      "layer": 2,
      "definition": "Multiple short labeled numeric values sharing a subject, geography, or period.",
      "positive_indicators": ["repeated label/value pairs", "short comparable metrics"],
      "negative_indicators": ["dense appendix table", "unrelated numbers in a paragraph"],
      "required_fields": ["metrics"],
      "optional_fields": ["shared_context"],
      "evidence_requirements": ["at least two metrics grounded in one source region"],
      "candidate_component_treatments": ["stat_card_grid", "metric_strip"],
      "common_false_positives": ["numbered lists"],
      "validation_rules": ["metrics must include at least two items"]
    },
    {
      "id": "question_list",
      "name": "Question List / Checklist",
      "layer": 2,
      "definition": "A sequence of related questions presented as a checklist or guide.",
      "positive_indicators": ["multiple question list items", "guide prompts"],
      "negative_indicators": ["isolated questions across unrelated sections"],
      "required_fields": ["questions"],
      "optional_fields": ["topic", "ordered"],
      "evidence_requirements": ["questions appear in source_refs"],
      "candidate_component_treatments": ["checklist", "faq_group"],
      "common_false_positives": ["paragraphs with many rhetorical questions"],
      "validation_rules": ["must contain at least two questions"]
    },
    {
      "id": "comparison_table",
      "name": "Comparison Table",
      "layer": 2,
      "definition": "A structured table comparing entities, categories, values, or options.",
      "positive_indicators": ["IR table", "row and cell structure", "header row"],
      "negative_indicators": ["layout-only table"],
      "required_fields": ["table_text"],
      "optional_fields": ["has_header", "comparison_dimensions"],
      "evidence_requirements": ["source_refs anchor to table node"],
      "candidate_component_treatments": ["responsive_table", "comparison_matrix"],
      "common_false_positives": ["single-column layout table"],
      "validation_rules": ["must anchor to IR table"]
    },
    {
      "id": "process_step_list",
      "name": "Process / Step List",
      "layer": 2,
      "definition": "A sequence of steps, phases, or actions.",
      "positive_indicators": ["ordered list", "imperative verbs", "process headings"],
      "negative_indicators": ["unordered examples without sequence"],
      "required_fields": ["steps"],
      "optional_fields": ["ordered", "actor"],
      "evidence_requirements": ["steps appear in source_refs"],
      "candidate_component_treatments": ["stepper", "process_list"],
      "common_false_positives": ["ordinary bullet list"],
      "validation_rules": ["must contain at least two steps"]
    }
  ]
}
