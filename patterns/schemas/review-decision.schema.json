{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://rk3.local/patterns/schemas/review-decision.schema.json",
  "title": "RK3 Pattern Review Decision",
  "type": "object",
  "required": ["schema", "document_id", "pattern_id", "decision", "reviewed_at"],
  "properties": {
    "schema": {"type": "integer", "minimum": 1},
    "document_id": {"type": "string"},
    "pattern_id": {"type": "string"},
    "pattern_type": {"type": "string"},
    "decision": {
      "enum": [
        "accept",
        "reject",
        "accept_with_edits",
        "wrong_type",
        "missing_fields",
        "needs_more_context",
        "useful_suggestion_not_supported"
      ]
    },
    "edits": {"type": "object"},
    "notes": {"type": "string"},
    "reviewer": {"type": "string"},
    "reviewed_at": {"type": "string"}
  }
}

