# source PDFs are large binaries; keep them out of the repo,
# but do keep the project docs and the per-document decision files
# (config + edit ops encode user judgment and must be versioned)
sources/*
!sources/docs/
!sources/0*/
sources/0*/*
!sources/0*/*.config.json
!sources/0*/*.ops.json
!sources/0*/*.landing.json
!sources/0*/*.landing-theme.json

# generated conversion artifacts (rebuildable from sources + code)
output/

# viewer annotations (scratch working data, per user decision)
feedback/

# secrets — API keys etc. (never commit)
.env
.env.*
!.env.example

# python
.venv/
__pycache__/
*.pyc

# node
node_modules/
app/ui/dist/
