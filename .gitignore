# source PDFs are large binaries; keep them out of the repo,
# but do keep the project docs and the per-document decision files
# (config + edit ops encode user judgment and must be versioned)
sources/*
!sources/docs/
!sources/0*/
sources/0*/*
!sources/0*/*.config.json
!sources/0*/*.ops.json
!sources/0*/*.landing.json
!sources/0*/*.landing-theme.json

# generated conversion artifacts: ignore the heavy, binary, regenerable bulk
# (page & figure PNGs, the raw per-char extract, intermediate blocks, debug
# logs — ~930M for 30 docs), but DO track the small, diffable, SEMANTIC outputs
# so an output change can be reviewed against the code change that caused it and
# improvement measured. ir.json = legs 1&2 (emphasis/link spans); index.html =
# leg 3 (render nesting, invisible in the IR). ~11M for 30 docs.
# NOTE: at ~30k docs this won't fit git — move to a golden-file/object store then.
output/*
!output/pdfium/
output/pdfium/*
!output/pdfium/*/
output/pdfium/*/*
!output/pdfium/*/ir.json
!output/pdfium/*/index.html
!output/pdfium/*/default.css
!output/pdfium/*/original.css
!output/pdfium/*/layout.css
!output/pdfium/*/embed.css

# viewer annotations (scratch working data, per user decision)
feedback/

# secrets — API keys etc. (never commit)
.env
.env.*
!.env.example

# python
.venv/
__pycache__/
*.pyc

# node
node_modules/
app/ui/dist/
